# ============================================================
#  TatT — DEMO MODE (.env.local)
#  Zero credentials needed. All external services are mocked.
#  Share this file with testers (Killua, YC, etc.)
# ============================================================

# ─── MASTER DEMO FLAG ──────────────────────────────────────
# Flip to false when real credentials are available.
NEXT_PUBLIC_DEMO_MODE=true

# ─── COUNCIL DEMO MODE ─────────────────────────────────────
# When true, the LLM enhancement council uses mock prompts
# instead of calling OpenRouter/Vertex AI.
NEXT_PUBLIC_COUNCIL_DEMO_MODE=true

# ─── FIREBASE (optional in demo mode) ─────────────────────
# Leave blank — the app detects missing credentials and skips
# Firebase Auth entirely. Designs save to localStorage.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Cookie keys — required to prevent next-firebase-auth-edge crash.
# These are dummy values for demo; any 32+ char hex string works.
AUTH_COOKIE_SIGNATURE_KEY_CURRENT=00000000000000000000000000000000
AUTH_COOKIE_SIGNATURE_KEY_PREVIOUS=11111111111111111111111111111111

# ─── NEO4J (optional in demo mode) ─────────────────────────
NEXT_PUBLIC_NEO4J_ENABLED=false

# ─── SUPABASE (optional in demo mode) ─────────────────────
# Artist matching uses demo data when NEXT_PUBLIC_DEMO_MODE=true.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# ─── REPLICATE (optional in demo mode) ────────────────────
# Image generation returns Unsplash stock photos in demo mode.
REPLICATE_API_TOKEN=

# ─── CORS / SERVER ─────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173
HOST=127.0.0.1
PORT=3002

# ─── OPENROUTER (optional in demo mode) ────────────────────
VITE_USE_OPENROUTER=false

# ─── GCP (optional in demo mode) ──────────────────────────
GCP_PROJECT_ID=

# ─── FEATURE FLAGS ─────────────────────────────────────────
NEXT_PUBLIC_ENABLE_INPAINTING=true
NEXT_PUBLIC_ENABLE_STENCIL_EXPORT=true
NEXT_PUBLIC_ENABLE_AR_PREVIEW=false
